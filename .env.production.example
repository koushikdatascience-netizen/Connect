# ===========================================
# SocialSync Production Environment Variables
# ===========================================
# Copy this file to .env.production and fill in your values
# These will be set in Railway dashboard

# --- Security & Encryption ---
# Generate with: python -c "import base64; print(base64.urlsafe_b64encode(__import__('cryptography').fernet.Fernet.generate_key()).decode())"
ENCRYPTION_KEY=your_base64_encryption_key_here

# --- Database (Railway PostgreSQL) ---
# Railway auto-generates this when you add PostgreSQL service
DATABASE_URL=postgresql://postgres:password@your-db.railway.internal:5432/railway

# --- Redis (Railway Redis) ---
# Railway auto-generates this when you add Redis service
REDIS_URL=redis://default:password@your-redis.railway.internal:6379

# --- OAuth: Facebook & Instagram ---
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/facebook/callback
INSTAGRAM_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/instagram/callback

# --- OAuth: LinkedIn ---
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/linkedin/callback

# --- OAuth: Google (YouTube) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/google/callback

# --- OAuth: Twitter (X) ---
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/twitter/callback

# --- Media Storage (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Server Configuration ---
# Your Railway backend URL (e.g., https://socialsync-backend.railway.app)
BACKEND_PUBLIC_URL=https://your-backend.railway.app

# Your Vercel frontend URL (e.g., https://socialsync.vercel.app)
FRONTEND_URL=https://your-frontend.vercel.app

# CORS - Add your Vercel URL here
ADDITIONAL_CORS_ORIGINS=https://your-frontend.vercel.app

API_V1_STR=/api/v1

# Security cookies for production
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=none

WEBVIEW_AUTH_CODE_TTL_SECONDS=60

# --- JWT Authentication ---
AUTH_REQUIRED=true
ALLOW_DEV_TENANT_HEADER=false
JWT_ALGORITHM=HS256

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your_long_random_jwt_secret_string_at_least_64_chars

JWT_ISSUER=SocialSync
JWT_AUDIENCE=SocialSync

# --- Multi-tenancy Claims ---
JWT_TENANT_CLAIM=TenantId
JWT_SUBJECT_CLAIM=UserId
JWT_ROLE_CLAIM=ISAdmin
QUERY_TENANT_PARAM=tenantId

# --- Celery Configuration ---
# Railway uses the REDIS_URL above for Celery broker/backend

# ====================================
# SocialSync Frontend Environment Variables
# ====================================
# Copy this file to .env.local and update with your values
# cp .env.example .env.local

# Backend API URL
# Local development: http://localhost:8000
# Vercel + ngrok testing: https://your-ngrok-domain.ngrok-free.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Tenant ID for multi-tenant support
# Change this to your actual tenant ID
NEXT_PUBLIC_TENANT_ID=tenant_123

# Local storage key for JWT token authentication
NEXT_PUBLIC_AUTH_TOKEN_STORAGE_KEY=snapkey_jwt

# Optional demo token for the temporary login screen
# Use the raw JWT only, without the "Bearer " prefix
NEXT_PUBLIC_DEBUG_BEARER_TOKEN=

# Optional Meta App Review demo fallback.
# When true, a Facebook OAuth "no pages returned" response enables a frontend-only Demo Page.
NEXT_PUBLIC_META_APP_REVIEW_DEMO=false

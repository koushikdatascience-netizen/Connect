# --- Security & Encryption ---
# Used for encrypting sensitive data in the database
ENCRYPTION_KEY=your_base64_encryption_key_here

# --- Database & Cache ---
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
REDIS_URL=redis://localhost:6379/0

# --- OAuth: Facebook & Instagram ---
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/facebook/callback
INSTAGRAM_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/instagram/callback

# --- OAuth: LinkedIn ---
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8000/api/v1/oauth/linkedin/callback

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=${BACKEND_PUBLIC_URL}/api/v1/oauth/google/callback

# --- OAuth: Twitter (X) ---
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_REDIRECT_URI=http://127.0.0.1:8000/api/v1/oauth/twitter/callback

# --- Media Storage (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Server Configuration ---
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ADDITIONAL_CORS_ORIGINS=https://your-production-app.vercel.app
API_V1_STR=/api/v1

# --- JWT Authentication ---
AUTH_REQUIRED=true
ALLOW_DEV_TENANT_HEADER=false
JWT_ALGORITHM=HS256
JWT_SECRET=your_long_random_jwt_secret_string
JWT_ISSUER=Snapkey
JWT_AUDIENCE=Snapkey

# --- Multi-tenancy Claims ---
JWT_TENANT_CLAIM=TenantId
JWT_SUBJECT_CLAIM=UserId
JWT_ROLE_CLAIM=ISAdmin
QUERY_TENANT_PARAM=tenantId

# --- Development Helpers ---
# Example Token for testing: Bearer <token>
DEBUG_BEARER_TOKEN=
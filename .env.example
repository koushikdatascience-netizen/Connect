ENCRYPTION_KEY=replace_with_generated_key
DATABASE_URL=postgresql://postgres:postgres@db:5432/socialsync
REDIS_URL=redis://redis:6379/0

PROJECT_NAME=SocialSync
API_V1_STR=/api/v1
AUTH_REQUIRED=false
ALLOW_DEV_TENANT_HEADER=true
JWT_ALGORITHM=HS256
JWT_SECRET=
JWT_PUBLIC_KEY=
JWT_AUDIENCE=Snapkey
JWT_ISSUER=Snapkey
JWT_TENANT_CLAIM=TenantId
JWT_SUBJECT_CLAIM=UserId
JWT_ROLE_CLAIM=ISAdmin
QUERY_TENANT_PARAM=tenantId

# Public URLs
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000
ADDITIONAL_CORS_ORIGINS=

# OAuth app credentials
FACEBOOK_CLIENT_ID=your_fb_id
FACEBOOK_SECRET=your_fb_secret
LINKEDIN_CLIENT_ID=your_linkedin_id
LINKEDIN_SECRET=your_linkedin_secret
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_SECRET=your_google_secret
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Optional OAuth callback overrides.
# Leave blank to auto-build from BACKEND_PUBLIC_URL.
FACEBOOK_REDIRECT_URI=
INSTAGRAM_REDIRECT_URI=
LINKEDIN_REDIRECT_URI=
GOOGLE_REDIRECT_URI=
TWITTER_REDIRECT_URI=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
